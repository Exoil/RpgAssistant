server {
    listen       80;
    server_name  _;

    root   /usr/share/nginx/html;
    index  index.html;

    # SPA fallback - kazda nieznana sciezka oddaje index.html,
    # zeby Vue Router obsluzyl routing po stronie klienta.
    # Routing /v1/* do api obsluguje gateway w nadrzednym compose,
    # wiec tutaj nie ma juz proxy do backendu.
    location / {
        try_files $uri $uri/ /index.html;
    }
}