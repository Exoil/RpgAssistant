# Copy this file as `.env` in the same directory and set your own password.
# Docker Compose reads the `.env` file next to docker-compose.yaml and
# substitutes ${...} variables when parsing the compose file.
NEO4J_PASSWORD=changeme

# Foundry VTT (felddy/foundryvtt:14). USERNAME/PASSWORD are your
# foundryvtt.com credentials — required on first run so the container can
# download the distribution. ADMIN_KEY is the Foundry setup-screen password.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=
FOUNDRY_ADMIN_KEY=changeme
# Optional: the long license key from your foundryvtt.com email
# (XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX). Leave empty when USERNAME/PASSWORD
# are set — the container will pull the license itself on first run.
FOUNDRY_LICENSE_KEY=
